# PostgreSQL (Neon, Supabase, Vercel Postgres, локальный Docker). Для Vercel — обязательно задать в Project → Environment Variables.
# Пример Neon: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Сессии пользователей (JWT)
AUTH_SECRET="change-me-to-long-random-string"

# Админ-панель: логин по email/паролю из БД (сид создаёт ADMIN_EMAIL)
ADMIN_EMAIL="admin@example.com"
# Только для локального сида / первого входа — в production задайте пароль через seed после смены
ADMIN_PASSWORD_PLAIN="change-me"

# Секрет подписи cookie админ-сессии
ADMIN_SESSION_SECRET="change-me-admin-session"

# Fragment
# partner_api | direct_wallet | disabled
FRAGMENT_MODE="disabled"
FRAGMENT_API_BASE_URL="https://v1.fragmentapi.com/api/v1/partner"
FRAGMENT_API_KEY=""
FRAGMENT_WEBHOOK_SECRET=""
FRAGMENT_WALLET_TYPE="TON"

# Режим B (прямой кошелёк) — не коммитьте реальные значения
# TON_WALLET_SEED=""
# FRAGMENT_SESSION_JSON=""
# TONAPI_KEY=""

# Текст заглушки оплаты (опционально переопределяет SiteSettings через константу — используйте БД в админке)
# PAYMENT_STUB_TEXT=""

# Публичный URL сайта (для webhook callback в проде)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
